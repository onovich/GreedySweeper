{
  "name": "greedy-sweeper",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "arch:check": "node scripts/architecture-check.mjs",
    "ai:evaluate": "node scripts/evaluate-ai-policies.mjs",
    "greed:evaluate": "node scripts/evaluate-greed-balance.mjs",
    "progression:evaluate": "node scripts/evaluate-progression.mjs",
    "protocol:evaluate": "node packages/online-protocol/evaluate.mjs",
    "worker:test": "node apps/room-worker/test.mjs",
    "worker:dry-run": "node apps/room-worker/dry-run.mjs",
    "workspace:check": "node scripts/workspace-check.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.19",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
