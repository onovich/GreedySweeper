{
  "name": "greedy-sweeper",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config apps/web/vite.config.js",
    "build": "vite build --config apps/web/vite.config.js",
    "preview": "vite preview --config apps/web/vite.config.js",
    "lint": "eslint .",
    "test": "vitest --config apps/web/vite.config.js",
    "test:run": "vitest run --config apps/web/vite.config.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "arch:check": "node scripts/architecture-check.mjs",
    "ai:evaluate": "node scripts/evaluate-ai-policies.mjs",
    "greed:evaluate": "node scripts/evaluate-greed-balance.mjs",
    "progression:evaluate": "node scripts/evaluate-progression.mjs",
    "protocol:evaluate": "node packages/online-protocol/evaluate.mjs",
    "online:evaluate": "node packages/online-protocol/online-evaluate.mjs",
    "worker:test": "vitest run --config apps/room-worker/vitest.config.js",
    "online:e2e": "vitest run --config apps/room-worker/vitest.config.js --testNamePattern=two-client",
    "online:resilience": "vitest run --config apps/room-worker/vitest.config.js --testNamePattern=\"hibernation|replaces|pauses|expires|abandons\"",
    "online:security": "npm run protocol:evaluate && vitest run --config apps/room-worker/vitest.config.js --testNamePattern=\"rate-limits|foundation\"",
    "online:load": "vitest run --config apps/room-worker/vitest.config.js --testNamePattern=capacity",
    "online:preview-smoke": "node scripts/smoke-preview.mjs",
    "online:free-beta-smoke": "node scripts/smoke-free-beta.mjs",
    "online:kill-switch-smoke": "node scripts/smoke-online-kill-switch.mjs",
    "visual:test": "playwright test --config apps/web/playwright.config.js visual-contract.spec.js",
    "visual:regression": "playwright test --config apps/web/playwright.config.js visual-regression.spec.js",
    "compat:test": "playwright test --config apps/web/playwright.config.js accessibility-compatibility.spec.js",
    "worker:dry-run": "wrangler deploy --config apps/room-worker/wrangler.jsonc --dry-run",
    "workspace:check": "node scripts/workspace-check.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.19",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0",
    "ws": "^8.21.0"
  }
}
